# Copy to .env and fill in as needed (never commit real secrets).

# Space-Track (optional — only if you use src/ingestion/spacetrack_client.py)
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# Embedded Cesium / Vite explorer origin (Streamlit explorer page iframe).
# Local full stack: http://localhost:5173
# Production (nginx layout in deploy/gcp): https://YOUR_PUBLIC_HOST/radar/
# DELPHI_RADAR_URL=http://127.0.0.1:5173

# Same public origin users open in the browser (no trailing slash). Needed for the home hero
# video when viewers are not on the same machine as Streamlit (e.g. ngrok, GCP + nginx).
# DELPHI_PUBLIC_BASE=https://YOUR_SUBDOMAIN.ngrok-free.app

# Extra CORS origins for FastAPI (comma-separated), e.g. your ngrok HTTPS URL.
# DELPHI_CORS_ORIGINS=https://YOUR_SUBDOMAIN.ngrok-free.app
