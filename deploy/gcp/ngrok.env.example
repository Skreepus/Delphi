# Example only — copy to ngrok.local.env (gitignored) if you prefer not to type the token on the CLI.
# Usage on the VM:
#   cp deploy/gcp/ngrok.env.example deploy/gcp/ngrok.local.env
#   nano deploy/gcp/ngrok.local.env   # set NGROK_AUTHTOKEN
#   set -a && source deploy/gcp/ngrok.local.env && set +a && ./deploy/gcp/install.sh
#
# Never commit ngrok.local.env or any file containing a real token.

NGROK_AUTHTOKEN=
